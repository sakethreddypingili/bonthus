# Copy to .env — Supabase Project Settings > API
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key
REACT_APP_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Scripts / tooling (same project)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-db-password

GENERATE_SOURCEMAP=false

# WhatsApp Business API - SECURE STORAGE ONLY
# NEVER hardcode these in source files
REACT_APP_WA_PHONE_NUMBER_ID=your-phone-number-id
REACT_APP_WA_ACCESS_TOKEN=your-access-token

# Database Configuration - Backend Only
# NEVER expose these in frontend code
SUPABASE_DB_HOST=your-db-host
SUPABASE_DB_USER=postgres

# Notes:
# 1. Add .env to .gitignore (already done)
# 2. Restart dev server after changing .env
# 3. Use deployment platform secrets for production
# 4. Never log environment variables or credentials
# 5. Rotate credentials immediately if exposed
